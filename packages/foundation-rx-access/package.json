{
  "name": "@foundation/rx-access-mcp",
  "version": "1.0.0",
  "description": "MCP server for prescription drug access — find patient assistance programs, check eligibility, compare drug costs, and locate pharmacies",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "foundation-rx-access": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
