  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "tax-preparation",
    "tax-deductions",
    "self-employed-taxes",
    "quarterly-taxes",
    "receipt-scanner",
    "freelancer-taxes",
    "mileage-deduction",
    "1099-contractor",
    "business-expenses",
    "irs-deadlines",
    "tax-calendar",
    "small-business-taxes",
    "ai-tax-assistant",
    "mama"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
