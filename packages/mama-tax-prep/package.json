{
  "name": "@mama/tax-prep-mcp",
  "version": "1.0.0",
  "description": "AI-powered tax preparation MCP server – receipt scanning, deduction finding, quarterly estimates, mileage, and tax calendar for freelancers and self-employed professionals",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mama-tax-prep": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "start": "node dist/index.js",
    "dev": "tsc --watch"
